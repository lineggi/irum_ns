---
import '../styles/global.css';
import { site, nav } from '../data/site.js';

const { title, description, active } = Astro.props;
const pageTitle = title ? `${title} | ${site.name}` : `${site.name} — ${site.tagline}`;
const desc = description ?? site.description;
// 링크 공유 시 나오는 대표 이미지(절대 URL) — 실도메인 연결 시 정상 노출
const ogImageUrl = site.ogImage ? new URL(site.ogImage, Astro.site).href : undefined;
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />

    {/* Google Analytics (GA4) */}
    {site.gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${site.gaId}`}></script>
        <script is:inline set:html={`
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', '${site.gaId}');
        `} />
      </>
    )}
    <meta name="theme-color" content="#16a34a" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:locale" content="ko_KR" />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {ogImageUrl && <meta property="og:image:width" content="1448" />}
    {ogImageUrl && <meta property="og:image:height" content="1086" />}
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <!-- 친근한 한글 폰트 Pretendard (CDN) -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css"
    />

    <!-- 구조화 데이터: 지역 사업자 -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'LocalBusiness',
      name: site.name,
      description: site.description,
      url: 'https://irumns.com',
      telephone: site.channels.tel,
      email: site.channels.email,
      address: { '@type': 'PostalAddress', addressCountry: 'KR', addressLocality: '남양주시', addressRegion: '경기도', streetAddress: site.business.address },
    })} />
  </head>
  <body>
    <header class="site-header">
      <div class="container bar">
        <a class="brand" href="/"><img class="brand-mark" src="/images/logo-mark.png" alt="" width="34" height="34" />이룸<span style="color:#16a34a">NS</span></a>
        <nav class="gnb" aria-label="주요 메뉴">
          {nav.map((item) => (
            <a href={item.href} aria-current={active === item.href ? 'page' : undefined}>{item.label}</a>
          ))}
        </nav>
        <div class="header-actions">
          <a class="btn btn-ghost" href={site.channels.kakao} target="_blank" rel="noopener">카톡 문의</a>
          <a class="btn btn-buy" href={site.storeUrl} target="_blank" rel="noopener">구매하기</a>
        </div>
        <details class="m-menu">
          <summary aria-label="메뉴 열기">☰</summary>
          <nav class="m-menu-panel" aria-label="모바일 메뉴">
            {nav.map((item) => (<a href={item.href} aria-current={active === item.href ? 'page' : undefined}>{item.label}</a>))}
            <a class="buy" href={site.storeUrl} target="_blank" rel="noopener">🛒 구매하기</a>
          </nav>
        </details>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div>
            <h4>{site.name}</h4>
            <p style="color:#aeb3ab">{site.tagline}</p>
            <a class="btn btn-buy" href={site.storeUrl} target="_blank" rel="noopener" style="margin-top:8px">🛒 스토어에서 구매하기</a>
          </div>
          <div>
            <h4>바로가기</h4>
            {nav.map((item) => (<p style="margin:0"><a href={item.href}>{item.label}</a></p>))}
          </div>
          <div>
            <h4>문의</h4>
            <p style="margin:0"><a href={site.channels.kakao} target="_blank" rel="noopener">카카오톡 문의</a></p>
            {site.channels.naverTalk && (<p style="margin:0"><a href={site.channels.naverTalk} target="_blank" rel="noopener">네이버 톡톡</a></p>)}
            <p style="margin:0"><a href={`tel:${site.channels.tel}`}>전화 {site.channels.tel}</a></p>
            <p style="margin:0"><a href={`mailto:${site.channels.email}`}>{site.channels.email}</a></p>
          </div>
        </div>
        <div class="biz">
          {site.business.company} · 대표 {site.business.owner} · 사업자등록번호 {site.business.bizNo}<br />
          {site.business.mailOrderNo && `통신판매업신고 ${site.business.mailOrderNo} · `}{site.business.address}<br />
          © {site.name}. 구매 안전거래는 네이버 스마트스토어에서 이루어집니다.
        </div>
      </div>
    </footer>

    <!-- 이미지 확대 보기(라이트박스) -->
    <div id="lightbox" aria-hidden="true" role="dialog" aria-label="이미지 크게 보기">
      <span class="x" aria-hidden="true">×</span>
      <img alt="확대 이미지" />
    </div>
    <script is:inline>
      (function () {
        var lb = document.getElementById('lightbox');
        var im = lb.querySelector('img');
        function close() { lb.classList.remove('open'); lb.setAttribute('aria-hidden', 'true'); im.removeAttribute('src'); }
        document.addEventListener('click', function (e) {
          var t = e.target.closest('img[data-zoom]');
          if (t) { im.src = t.getAttribute('data-full') || t.currentSrc || t.src; lb.classList.add('open'); lb.setAttribute('aria-hidden', 'false'); return; }
          if (e.target.closest('#lightbox')) close();
        });
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
      })();
    </script>

    <!-- 모바일 하단 고정 액션바 -->
    <nav class="mobile-bar" aria-label="빠른 실행">
      <a href={`tel:${site.channels.tel}`}><span class="ico">📞</span>전화</a>
      <a href={site.channels.kakao} target="_blank" rel="noopener"><span class="ico">💬</span>문의</a>
      <a class="buy" href={site.storeUrl} target="_blank" rel="noopener"><span class="ico">🛒</span>구매하기</a>
    </nav>
  </body>
</html>
