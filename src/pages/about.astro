---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site.js';
const b = site.business;
---

<BaseLayout title="회사소개" active="/about/" description="이룸엔에스는 미끄럼 방지 논슬립 전문 브랜드입니다. 국내 생산 · 합리적 가격 · 쉬운 셀프시공.">
  <section style="background:linear-gradient(180deg,#ecfdf5,#fbfaf7);">
    <div style="max-width:1080px; margin:0 auto; padding:44px 20px 34px;">
      <div style="font-size:13px; color:#6b7280; margin-bottom:8px;"><a href="/">홈</a> / 회사소개</div>
      <h1 style="font-size:34px; font-weight:800; letter-spacing:-.02em; margin:0 0 8px;">회사소개</h1>
      <p style="font-size:16px; color:#4b5563; max-width:52ch;">이룸엔에스는 미끄럼 방지 논슬립 전문 브랜드입니다. 누구나 안심하고 걷는 일상을 만듭니다.</p>
    </div>
  </section>

  <!-- 미션 -->
  <section style="max-width:1080px; margin:0 auto; padding:50px 20px;">
    <div class="about-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:36px; align-items:center;">
      <div>
        <div style="font-weight:700; font-size:13px; color:#15803d;">우리의 약속</div>
        <h2 style="font-size:28px; font-weight:800; letter-spacing:-.02em; margin:8px 0 14px;">미끄럼 걱정 없이,<br />안심하는 일상</h2>
        <p style="font-size:15.5px; color:#4b5563; line-height:1.8;">계단·현관·경사로의 작은 미끄러짐은 큰 사고로 이어집니다. 이룸엔에스는 국내에서 생산한 튼튼한 논슬립과 현장에서 쌓은 시공 노하우로, 가정부터 건물까지 오래가는 안전을 제공합니다. 개인 구매자도 혼자 시공할 수 있도록 쉬운 가이드까지 함께 드립니다.</p>
      </div>
      <img src="/images/cases/case004.jpg" alt="시공 현장" style="width:100%; aspect-ratio:4/3; object-fit:cover; border-radius:22px; box-shadow:0 18px 40px rgba(31,41,55,.14);" />
    </div>
  </section>

  <!-- 가치 -->
  <section style="background:#fff; border-top:1px solid #ecece6; border-bottom:1px solid #ecece6;">
    <div style="max-width:1080px; margin:0 auto; padding:52px 20px;">
      <div class="value-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:20px;">
        <div style="background:#fbfaf7; border:1px solid #ecece6; border-radius:20px; padding:28px;"><div style="font-size:26px; font-weight:800; color:#16a34a;">국내 생산</div><div style="font-weight:800; font-size:17px; margin-top:8px;">믿을 수 있는 품질</div><p style="font-size:14px; color:#6b7280; margin-top:6px;">해지지 않는 내구성과 강한 접착력으로 오래 갑니다.</p></div>
        <div style="background:#fbfaf7; border:1px solid #ecece6; border-radius:20px; padding:28px;"><div style="font-size:26px; font-weight:800; color:#16a34a;">합리적 가격</div><div style="font-weight:800; font-size:17px; margin-top:8px;">개인도 부담 없이</div><p style="font-size:14px; color:#6b7280; margin-top:6px;">시공 업체를 부르지 않고도 저렴하게 해결하도록.</p></div>
        <div style="background:#fbfaf7; border:1px solid #ecece6; border-radius:20px; padding:28px;"><div style="font-size:26px; font-weight:800; color:#16a34a;">쉬운 시공</div><div style="font-weight:800; font-size:17px; margin-top:8px;">가이드 + 상담</div><p style="font-size:14px; color:#6b7280; margin-top:6px;">사진 가이드와 메시지 상담으로 초보도 30분 완성.</p></div>
      </div>
    </div>
  </section>

  <!-- 사업자 정보 -->
  <section style="max-width:1080px; margin:0 auto; padding:52px 20px 30px;">
    <h2 style="font-size:22px; font-weight:800; letter-spacing:-.02em; margin:0 0 18px;">사업자 정보</h2>
    <table style="width:100%; border-collapse:collapse; border:1px solid #ecece6; border-radius:16px; overflow:hidden; font-size:14.5px; background:#fff;">
      <tr><th style="text-align:left; width:28%; background:#ecfdf5; color:#15803d; font-weight:700; padding:14px 18px; border-bottom:1px solid #ecece6;">상호</th><td style="padding:14px 18px; border-bottom:1px solid #ecece6;">{b.company}</td></tr>
      <tr><th style="text-align:left; background:#ecfdf5; color:#15803d; font-weight:700; padding:14px 18px; border-bottom:1px solid #ecece6;">대표</th><td style="padding:14px 18px; border-bottom:1px solid #ecece6;">{b.owner}</td></tr>
      <tr><th style="text-align:left; background:#ecfdf5; color:#15803d; font-weight:700; padding:14px 18px; border-bottom:1px solid #ecece6;">사업자등록번호</th><td style="padding:14px 18px; border-bottom:1px solid #ecece6;">{b.bizNo}</td></tr>
      <tr><th style="text-align:left; background:#ecfdf5; color:#15803d; font-weight:700; padding:14px 18px; border-bottom:1px solid #ecece6;">주소</th><td style="padding:14px 18px; border-bottom:1px solid #ecece6;">{b.address}</td></tr>
      <tr><th style="text-align:left; background:#ecfdf5; color:#15803d; font-weight:700; padding:14px 18px;">연락처</th><td style="padding:14px 18px;">{site.channels.tel} · {site.channels.email}</td></tr>
    </table>
  </section>

  <section style="max-width:1080px; margin:0 auto; padding:20px 20px 58px;">
    <div style="background:linear-gradient(120deg,#16a34a,#15803d); border-radius:24px; padding:40px; text-align:center;">
      <h2 style="color:#fff; font-size:24px; font-weight:800; margin:0 0 8px; letter-spacing:-.02em;">궁금한 점이 있으신가요?</h2>
      <p style="color:rgba(255,255,255,.92); font-size:15px; margin:0 auto 22px; max-width:44ch;">제품·시공 무엇이든 편하게 문의하세요.</p>
      <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;"><a href="/contact/" style="padding:14px 26px; border-radius:999px; font-weight:800; font-size:16px; color:#15803d; background:#fff;">문의하기 →</a><a href={site.storeUrl} target="_blank" rel="noopener" style="padding:14px 26px; border-radius:999px; font-weight:800; font-size:16px; color:#fff; background:rgba(255,255,255,.18); border:1.5px solid rgba(255,255,255,.5);">스마트스토어</a></div>
    </div>
  </section>
</BaseLayout>

<style>
  @media (max-width: 820px) {
    .about-grid { grid-template-columns: 1fr !important; }
    .value-grid { grid-template-columns: 1fr !important; }
  }
</style>
