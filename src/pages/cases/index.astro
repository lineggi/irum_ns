---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const cases = (await getCollection('cases'))
  .map((c) => ({ img: c.data.image, title: c.data.title, note: c.data.note, order: c.data.order ?? 100 }))
  .sort((a, b) => a.order - b.order);
---

<BaseLayout title="시공사례" active="/cases/" description="아파트 계단·상가 경사로 등 이룸엔에스가 직접 시공한 논슬립 현장 사진을 확인하세요.">
  <section style="background:linear-gradient(180deg,#ecfdf5,#fbfaf7);">
    <div style="max-width:1080px; margin:0 auto; padding:44px 20px 34px;">
      <div style="font-size:13px; color:#6b7280; margin-bottom:8px;"><a href="/">홈</a> / 시공사례</div>
      <h1 style="font-size:34px; font-weight:800; letter-spacing:-.02em; margin:0 0 8px;">시공사례</h1>
      <p style="font-size:16px; color:#4b5563; max-width:52ch;">계단·경사로 미끄럼 방지, 실제 현장에서 확인하세요. 모두 이룸엔에스가 직접 시공한 사진입니다.</p>
    </div>
  </section>

  <section style="max-width:1080px; margin:0 auto; padding:40px 20px 58px;">
    <div class="case-grid" style="display:grid; grid-template-columns:repeat(4,1fr); gap:16px;">
      {cases.map((c) => (
        <figure class="gcell" style="margin:0; background:#fff; border:1px solid #ecece6; border-radius:18px; overflow:hidden; box-shadow:0 6px 20px rgba(31,41,55,.06);">
          <img src={c.img} alt={c.title} data-zoom data-full={c.img} style="width:100%; aspect-ratio:3/4; object-fit:cover;" />
          <figcaption style="padding:12px 16px;"><div style="font-weight:700; font-size:14px;">{c.title}</div><div style="font-size:12.5px; color:#6b7280;">{c.note}</div></figcaption>
        </figure>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .gcell { transition: transform .15s ease, box-shadow .15s ease; }
  .gcell:hover { transform: translateY(-4px); box-shadow: 0 14px 34px rgba(31, 41, 55, .14); }
  @media (max-width: 820px) { .case-grid { grid-template-columns: repeat(2, 1fr) !important; } }
</style>
