---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site.js';
---

<BaseLayout title="문의하기" active="/contact/" description="제품·수량·시공 문의는 카카오톡·전화·이메일로. 시공 부위 사진과 함께 문의 주시면 맞는 규격을 안내합니다.">
  <section style="background:linear-gradient(180deg,#ecfdf5,#fbfaf7);">
    <div style="max-width:1080px; margin:0 auto; padding:44px 20px 34px;">
      <div style="font-size:13px; color:#6b7280; margin-bottom:8px;"><a href="/">홈</a> / 문의하기</div>
      <h1 style="font-size:34px; font-weight:800; letter-spacing:-.02em; margin:0 0 8px;">문의하기</h1>
      <p style="font-size:16px; color:#4b5563; max-width:52ch;">시공 부위 사진과 함께 문의 주시면, 맞는 규격·색상과 필요한 수량을 안내해 드립니다.</p>
    </div>
  </section>

  <!-- 채널 -->
  <section style="max-width:1080px; margin:0 auto; padding:44px 20px 20px;">
    <div class="chan-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px;">
      <a href={site.channels.kakao} target="_blank" rel="noopener" class="chan" style="display:block; background:#fee500; border-radius:20px; padding:26px; box-shadow:0 6px 20px rgba(31,41,55,.06);">
        <div style="font-weight:800; font-size:19px; color:#3c1e1e;">카카오톡 채널</div>
        <p style="font-size:14px; color:#5b3d1e; margin-top:6px;">가장 빠른 상담. 사진 첨부 문의 가능.</p>
        <div style="margin-top:16px; font-weight:800; font-size:14px; color:#3c1e1e;">채널 열기 →</div>
      </a>
      <a href={`tel:${site.channels.tel}`} class="chan" style="display:block; background:#16a34a; border-radius:20px; padding:26px; box-shadow:0 6px 20px rgba(31,41,55,.06);">
        <div style="font-weight:800; font-size:19px; color:#fff;">전화 문의</div>
        <p style="font-size:14px; color:rgba(255,255,255,.9); margin-top:6px;">통화로 바로 상담을 원하시면.</p>
        <div style="margin-top:16px; font-weight:800; font-size:16px; color:#fff;">{site.channels.tel}</div>
      </a>
      <a href={`mailto:${site.channels.email}`} class="chan" style="display:block; background:#fff; border:1px solid #ecece6; border-radius:20px; padding:26px; box-shadow:0 6px 20px rgba(31,41,55,.06);">
        <div style="font-weight:800; font-size:19px; color:#1f2937;">이메일</div>
        <p style="font-size:14px; color:#6b7280; margin-top:6px;">견적·대량 구매 문의는 메일로.</p>
        <div style="margin-top:16px; font-weight:800; font-size:14px; color:#15803d;">{site.channels.email}</div>
      </a>
    </div>
  </section>

  <!-- 상담 안내 -->
  <section style="max-width:1080px; margin:0 auto; padding:26px 20px 20px;">
    <div class="contact-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:16px; align-items:start;">
      <div style="background:#ecfdf5; border:1px solid #d1fae5; border-radius:18px; padding:22px;">
        <div style="font-weight:800; font-size:16px; color:#15803d;">상담 안내</div>
        <div style="display:grid; gap:10px; margin-top:12px; font-size:14px; color:#4b5563;">
          <div><b style="color:#1f2937;">운영시간</b><br />평일 09:00 – 18:00</div>
          <div><b style="color:#1f2937;">주소</b><br />{site.business.address}</div>
        </div>
      </div>
      <div style="background:#fff7ed; border:1px solid #fed7aa; border-radius:18px; padding:22px;">
        <div style="font-weight:800; font-size:16px; color:#9a3412;">문의 전 팁</div>
        <p style="font-size:13.5px; color:#9a3412; margin-top:8px; line-height:1.6;">시공 부위 사진과 대략적인 길이를 알려주시면 훨씬 정확하게 안내해 드릴 수 있어요. 카카오톡 채널로 사진을 첨부해 문의하시면 가장 빠릅니다.</p>
      </div>
    </div>
  </section>

  <section style="max-width:1080px; margin:0 auto; padding:26px 20px 58px;">
    <div style="background:linear-gradient(120deg,#f97316,#ea580c); border-radius:24px; padding:36px; text-align:center;">
      <h2 style="color:#fff; font-size:22px; font-weight:800; margin:0 0 8px; letter-spacing:-.02em;">이미 원하는 제품을 아신다면</h2>
      <p style="color:rgba(255,255,255,.92); font-size:15px; margin:0 auto 20px; max-width:40ch;">스마트스토어에서 바로 주문하실 수 있습니다.</p>
      <a href={site.storeUrl} target="_blank" rel="noopener" style="padding:14px 28px; border-radius:999px; font-weight:800; font-size:16px; color:#ea580c; background:#fff;">스마트스토어 구매하기 →</a>
    </div>
  </section>

</BaseLayout>

<style>
  .chan { transition: transform .12s ease, box-shadow .12s ease; }
  .chan:hover { transform: translateY(-3px); box-shadow: 0 12px 28px rgba(31, 41, 55, .12); }
  @media (max-width: 820px) {
    .chan-grid { grid-template-columns: 1fr !important; }
    .contact-grid { grid-template-columns: 1fr !important; }
  }
</style>
