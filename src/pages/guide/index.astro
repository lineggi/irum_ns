---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../data/site.js';
import { guides } from '../../data/content.js';
---

<BaseLayout title="시공가이드" active="/guide/" description="계단 논슬립·마감재 셀프 시공 방법을 단계별로. 공구만 있으면 초보자도 30분이면 완성.">
  <section style="background:linear-gradient(180deg,#ecfdf5,#fbfaf7);">
    <div style="max-width:1080px; margin:0 auto; padding:44px 20px 34px;">
      <div style="font-size:13px; color:#6b7280; margin-bottom:8px;"><a href="/">홈</a> / 시공가이드</div>
      <h1 style="font-size:34px; font-weight:800; letter-spacing:-.02em; margin:0 0 8px;">시공가이드</h1>
      <p style="font-size:16px; color:#4b5563; max-width:52ch;">공구만 있으면 초보자도 30분. 사진과 함께 따라 하면 혼자서도 깔끔하게 시공할 수 있어요.</p>
    </div>
  </section>

  {guides.map((g) => (
    <section id={g.slug} style="max-width:1080px; margin:0 auto; padding:44px 20px 10px; scroll-margin-top:76px;">
      <div class="guide-head" style="display:grid; grid-template-columns:1fr 1fr; gap:28px; align-items:center; background:#fff; border:1px solid #ecece6; border-radius:22px; overflow:hidden; box-shadow:0 6px 20px rgba(31,41,55,.06);">
        <img src={g.img} alt={g.title} style="width:100%; height:100%; object-fit:cover; min-height:260px;" />
        <div style="padding:30px 30px 30px 6px;">
          <div style="display:flex; gap:8px; margin-bottom:12px;"><span style="font-size:13px; font-weight:600; color:#15803d; background:#d1fae5; padding:4px 11px; border-radius:999px;">{g.level}</span><span style="font-size:13px; font-weight:600; color:#9a3412; background:#fff7ed; border:1px solid #fed7aa; padding:4px 11px; border-radius:999px;">약 {g.minutes}분</span></div>
          <h2 style="font-size:24px; font-weight:800; letter-spacing:-.02em; margin:0 0 8px;">{g.title}</h2>
          <p style="font-size:15px; color:#4b5563;">{g.summary}</p>
        </div>
      </div>
      <div style="display:grid; gap:12px; margin-top:20px;">
        {g.steps.map((s, i) => (
          <div style="display:grid; grid-template-columns:44px 1fr; gap:16px; align-items:start; background:#fff; border:1px solid #ecece6; border-radius:16px; padding:18px 20px;">
            <div style="width:44px; height:44px; border-radius:50%; background:#ecfdf5; color:#15803d; font-weight:800; display:flex; align-items:center; justify-content:center;">{i + 1}</div>
            <div><div style="font-weight:800; font-size:16px;">{s.t}</div><p style="font-size:14.5px; color:#4b5563; margin-top:3px;">{s.d}</p></div>
          </div>
        ))}
      </div>
      {g.faq && g.faq.length > 0 && (
        <div style="margin-top:18px; display:grid; gap:10px;">
          {g.faq.map((f) => (
            <div style="background:#fff; border:1px solid #ecece6; border-radius:14px; padding:16px 20px;"><div style="font-weight:700; font-size:14.5px;">Q. {f.q}</div><p style="font-size:14px; color:#4b5563; margin-top:4px;">{f.a}</p></div>
          ))}
        </div>
      )}
    </section>
  ))}

  <section style="max-width:1080px; margin:0 auto; padding:36px 20px 58px;">
    <div style="background:linear-gradient(120deg,#16a34a,#15803d); border-radius:24px; padding:40px; text-align:center;">
      <h2 style="color:#fff; font-size:24px; font-weight:800; margin:0 0 8px; letter-spacing:-.02em;">시공이 어려우면 물어보세요</h2>
      <p style="color:rgba(255,255,255,.92); font-size:15px; margin:0 auto 22px; max-width:44ch;">시공 부위 사진을 보내주시면 필요한 제품과 방법을 안내해 드립니다.</p>
      <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;"><a href={site.channels.kakao} target="_blank" rel="noopener" style="padding:14px 26px; border-radius:999px; font-weight:800; font-size:16px; color:#1f2937; background:#fee500;">카카오톡 문의</a><a href="/products/" style="padding:14px 26px; border-radius:999px; font-weight:800; font-size:16px; color:#15803d; background:#fff; border:1px solid #ecece6;">제품 보기</a></div>
    </div>
  </section>
</BaseLayout>

<style>
  @media (max-width: 820px) { .guide-head { grid-template-columns: 1fr !important; } }
</style>
