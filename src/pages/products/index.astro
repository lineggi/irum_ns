---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../data/site.js';
import { catalog } from '../../data/products.js';
---

<BaseLayout title="제품소개" active="/products/" description="논슬립(테이프·세라믹·알루미늄), 마감재, 굽도리, 접착 부자재. 카테고리를 선택하면 제품 상세 이미지를 한눈에 볼 수 있습니다.">
  <section class="page-head">
    <div class="container">
      <div class="breadcrumb"><a href="/">홈</a> · 제품소개</div>
      <h1>제품소개</h1>
      <p class="lead">보고 싶은 제품을 선택하세요. 구매는 상단 <strong>구매하기</strong>(스마트스토어)에서 진행됩니다.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <!-- 1단계: 카테고리 탭 -->
      <div class="cat-tabs" role="tablist" aria-label="제품 카테고리">
        {catalog.map((c, ci) => (
          <button class="cat-tab" type="button" data-cat={c.slug} role="tab" aria-selected={ci === 0 ? 'true' : 'false'}>{c.name}</button>
        ))}
      </div>

      {catalog.map((c, ci) => (
        <div class="cat-panel" data-cat={c.slug} hidden={ci !== 0}>
          {/* 2단계: 제품 탭 (제품이 2개 이상일 때만) */}
          {c.products.length > 1 && (
            <div class="prod-tabs" role="tablist" aria-label={`${c.name} 제품`}>
              {c.products.map((p, pi) => (
                <button class="prod-tab" type="button" data-prod={String(pi)} role="tab" aria-selected={pi === 0 ? 'true' : 'false'}>{p.name}</button>
              ))}
            </div>
          )}

          {c.products.map((p, pi) => (
            <div class="prod-panel" data-prod={String(pi)} hidden={pi !== 0}>
              <h2 class="tong-title">{p.name}</h2>
              <div class="tong-wrap">
                {p.images.map((src) => (
                  <img class="tong" src={src} alt={`${p.name} 상세 이미지`} data-zoom loading="lazy" />
                ))}
              </div>
              <div class="tong-cta">
                <a class="btn btn-buy" href={site.storeUrl} target="_blank" rel="noopener">🛒 스토어에서 구매하기</a>
                <a class="btn btn-ghost" href="/contact/">💬 규격·수량 문의</a>
              </div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>

  <script is:inline>
    (function () {
      var catTabs = Array.prototype.slice.call(document.querySelectorAll('.cat-tab'));
      function showProd(panel, idx) {
        panel.querySelectorAll('.prod-panel').forEach(function (pp) { pp.hidden = pp.dataset.prod !== idx; });
        panel.querySelectorAll('.prod-tab').forEach(function (b) { b.setAttribute('aria-selected', b.dataset.prod === idx ? 'true' : 'false'); });
      }
      function showCat(slug) {
        document.querySelectorAll('.cat-panel').forEach(function (p) { p.hidden = p.dataset.cat !== slug; });
        catTabs.forEach(function (b) { b.setAttribute('aria-selected', b.dataset.cat === slug ? 'true' : 'false'); });
        var panel = document.querySelector('.cat-panel[data-cat="' + slug + '"]');
        if (panel) { var first = panel.querySelector('.prod-tab'); showProd(panel, first ? first.dataset.prod : '0'); }
      }
      catTabs.forEach(function (b) {
        b.addEventListener('click', function () { showCat(b.dataset.cat); history.replaceState(null, '', '#' + b.dataset.cat); });
      });
      document.querySelectorAll('.prod-tab').forEach(function (b) {
        b.addEventListener('click', function () { showProd(b.closest('.cat-panel'), b.dataset.prod); });
      });
      var initial = (location.hash || '').replace('#', '');
      if (catTabs.some(function (b) { return b.dataset.cat === initial; })) showCat(initial);
    })();
  </script>
</BaseLayout>
