---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { site } from '../../data/site.js';

// 어드민(Sveltia CMS)에서 관리하는 제품 컬렉션을 불러와 정렬
const allProducts = (await getCollection('products'))
  .map((e) => e.data)
  .sort((a, b) => a.order - b.order);

// 카테고리 순서·앵커·부제 (카테고리 네비/섹션 공통)
const CATS = [
  { key: '논슬립', id: 'nonslip', sub: '계단·출입구 미끄럼 방지 핵심 제품' },
  { key: '마감재', id: 'finish', sub: '타일·바닥 끝단 마감용 알루미늄' },
  { key: '굽도리', id: 'skirting', sub: '벽·바닥 경계 걸레받이' },
  { key: '기타', id: 'etc', sub: '시공용 접착 부자재' },
];
const byCat = (key) => allProducts.filter((p) => p.category === key);
---

<BaseLayout title="제품소개" active="/products/" description="논슬립(테이프·세라믹·알루미늄), 마감재, 굽도리, 접착 부자재. 규격·색상까지 확인하고 스마트스토어에서 구매하세요.">
  <!-- PAGE HEAD -->
  <section style="background:linear-gradient(180deg,#ecfdf5,#fbfaf7);">
    <div style="max-width:1080px; margin:0 auto; padding:44px 20px 34px;">
      <div style="font-size:13px; color:#6b7280; margin-bottom:8px;"><a href="/">홈</a> / 제품소개</div>
      <h1 style="font-size:34px; font-weight:800; letter-spacing:-.02em; margin:0 0 8px;">제품소개</h1>
      <p style="font-size:16px; color:#4b5563; max-width:52ch;">용도별 논슬립·마감재·굽도리·부자재. 규격과 색상까지 확인하고, 구매는 스마트스토어에서.</p>
    </div>
  </section>

  <!-- CATEGORY NAV -->
  <div style="max-width:1080px; margin:0 auto; padding:28px 20px 0;">
    <div class="cat-grid" style="display:grid; grid-template-columns:repeat(4,1fr); gap:12px;">
      <a href="#nonslip" class="catcard" style="background:#fff; border:1px solid #ecece6; border-radius:16px; padding:18px 20px; display:block;"><div style="font-weight:800; font-size:17px; color:#1f2937;">논슬립</div><div style="font-size:13px; color:#6b7280; margin-top:3px;">테이프·세라믹·알루미늄</div></a>
      <a href="#finish" class="catcard" style="background:#fff; border:1px solid #ecece6; border-radius:16px; padding:18px 20px; display:block;"><div style="font-weight:800; font-size:17px; color:#1f2937;">마감재</div><div style="font-size:13px; color:#6b7280; margin-top:3px;">데코트림·프로파일</div></a>
      <a href="#skirting" class="catcard" style="background:#fff; border:1px solid #ecece6; border-radius:16px; padding:18px 20px; display:block;"><div style="font-weight:800; font-size:17px; color:#1f2937;">굽도리</div><div style="font-size:13px; color:#6b7280; margin-top:3px;">월베이스·우드·무지</div></a>
      <a href="#etc" class="catcard" style="background:#fff; border:1px solid #ecece6; border-radius:16px; padding:18px 20px; display:block;"><div style="font-weight:800; font-size:17px; color:#1f2937;">기타 부자재</div><div style="font-size:13px; color:#6b7280; margin-top:3px;">양면테이프·접착제</div></a>
    </div>
  </div>

  <!-- ===== 필요 수량 계산기 ===== -->
  <section id="calc" style="max-width:1080px; margin:0 auto; padding:36px 20px 6px; scroll-margin-top:76px;">
    <div style="background:#fff; border:1px solid #ecece6; border-radius:22px; padding:28px; box-shadow:0 6px 20px rgba(31,41,55,.06);">
      <div style="display:flex; align-items:center; gap:10px; margin-bottom:4px; flex-wrap:wrap;"><span style="width:8px; height:26px; border-radius:4px; background:#16a34a;"></span><h2 style="font-size:22px; font-weight:800; letter-spacing:-.02em; margin:0;">필요 수량 계산기</h2></div>
      <p style="font-size:14.5px; color:#6b7280; margin:2px 0 0;">계단 단수와 폭을 입력하면 대략 필요한 길이와 수량을 알려드려요.</p>
      <div class="calc-grid" style="display:grid; grid-template-columns:1fr 1fr 1.2fr; gap:14px; margin-top:18px;">
        <label style="display:block;"><span style="font-size:13px; font-weight:700; color:#4b5563;">계단 단수</span><input id="calc-steps" type="number" min="1" inputmode="numeric" placeholder="예: 15" class="calc-in" /></label>
        <label style="display:block;"><span style="font-size:13px; font-weight:700; color:#4b5563;">한 단 폭</span>
          <div style="display:flex; gap:8px;">
            <input id="calc-width" type="number" min="1" inputmode="numeric" placeholder="예: 100" class="calc-in" style="margin-top:6px;" />
            <select id="calc-unit" class="calc-in" style="margin-top:6px; width:82px; flex:0 0 auto;"><option value="cm">cm</option><option value="mm">mm</option></select>
          </div>
        </label>
        <label style="display:block;"><span style="font-size:13px; font-weight:700; color:#4b5563;">제품 종류</span>
          <select id="calc-type" class="calc-in"><option value="tape">논슬립 테이프 (롤)</option><option value="bar">각 논슬립 (세라믹·알루미늄)</option></select>
        </label>
      </div>
      <div id="calc-result" style="margin-top:18px; background:#ecfdf5; border:1px solid #d1fae5; border-radius:16px; padding:18px 20px; font-size:15px; color:#166534; line-height:1.7;">계단 단수와 한 단 폭을 입력해 주세요.</div>
      <p style="font-size:12px; color:#9aa197; margin-top:10px;">* 재단 손실을 감안해 약 10% 여유를 더한 값입니다. 정확한 규격·수량은 주문 전 카카오톡으로 확인해 주세요.</p>
    </div>
  </section>

  <!-- ===== 카테고리별 제품 (어드민 컬렉션 기반) ===== -->
  {CATS.map((cat) => {
    const items = byCat(cat.key);
    if (items.length === 0) return null;
    return (
      <section id={cat.id} style="max-width:1080px; margin:0 auto; padding:46px 20px 10px; scroll-margin-top:76px;">
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:22px; flex-wrap:wrap;"><span style="width:8px; height:26px; border-radius:4px; background:#16a34a;"></span><h2 style="font-size:24px; font-weight:800; letter-spacing:-.02em; margin:0;">{cat.key}</h2><span style="font-size:14px; color:#6b7280;">{cat.sub}</span></div>
        {items.map((p) => {
          const colors = [...new Set([...(p.presetColors || []), ...(p.colors || [])])];
          return (
            <div class="prod-detail" style="display:grid; grid-template-columns:.9fr 1.1fr; gap:28px; background:#fff; border:1px solid #ecece6; border-radius:22px; padding:24px; box-shadow:0 6px 20px rgba(31,41,55,.06); margin-bottom:20px;">
              <img src={p.image} alt={p.name} data-zoom data-full={p.image} style="width:100%; border-radius:16px; border:1px solid #ecece6;" />
              <div>
                <div style="font-weight:800; font-size:21px; color:#1f2937;">{p.name}</div>
                {p.desc && (<p style="font-size:15px; color:#4b5563; margin:6px 0 16px;">{p.desc}</p>)}
                {p.badges.length > 0 && (
                  <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:16px;">
                    {p.badges.map((b) => (<span style="font-size:13px; font-weight:600; color:#15803d; background:#d1fae5; padding:4px 11px; border-radius:999px;">{b}</span>))}
                  </div>
                )}
                {p.feats.length > 0 && (
                  <ul style="list-style:none; padding:0; margin:0 0 18px; display:grid; gap:8px;">
                    {p.feats.map((f) => (<li style="padding-left:26px; position:relative; font-size:14.5px;"><span style="position:absolute; left:0; color:#16a34a; font-weight:800;">✓</span>{f}</li>))}
                  </ul>
                )}
                {p.specs.length > 0 && (
                  <table style="width:100%; border-collapse:collapse; border:1px solid #ecece6; border-radius:12px; overflow:hidden; font-size:14px;">
                    {p.specs.map((s, i) => (
                      <tr><th style={`text-align:left; width:34%; background:#ecfdf5; color:#15803d; font-weight:700; padding:10px 14px;${i < p.specs.length - 1 ? ' border-bottom:1px solid #ecece6;' : ''}`}>{s.label}</th><td style={`padding:10px 14px;${i < p.specs.length - 1 ? ' border-bottom:1px solid #ecece6;' : ''}`}>{s.value}</td></tr>
                    ))}
                  </table>
                )}
                {colors.length > 0 && (
                  <div style="display:flex; flex-wrap:wrap; gap:8px; margin-top:14px; align-items:center;">
                    <span style="font-size:13px; color:#6b7280; font-weight:600;">색상</span>
                    {colors.map((c) => (
                      <span style={`width:22px; height:22px; border-radius:6px; border:1px solid rgba(0,0,0,.12); background:${c};`}></span>
                    ))}
                  </div>
                )}
                {p.note && (<div style="background:#fff7ed; border:1px solid #fed7aa; color:#9a3412; border-radius:12px; padding:12px 16px; font-weight:600; font-size:13.5px; margin-top:14px;">{p.note}</div>)}
              </div>
            </div>
          );
        })}
      </section>
    );
  })}

  <!-- BUY CTA -->
  <section style="max-width:1080px; margin:0 auto; padding:20px 20px 58px;">
    <div style="background:linear-gradient(120deg,#f97316,#ea580c); border-radius:24px; padding:40px; text-align:center;">
      <h2 style="color:#fff; font-size:24px; font-weight:800; margin:0 0 8px; letter-spacing:-.02em;">구매는 스마트스토어에서</h2>
      <p style="color:rgba(255,255,255,.92); font-size:15px; margin:0 auto 22px; max-width:44ch;">규격·색상이 헷갈리면 카카오톡으로 먼저 물어보세요. 맞는 제품을 안내해 드립니다.</p>
      <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;"><a href={site.storeUrl} target="_blank" rel="noopener" style="padding:14px 28px; border-radius:999px; font-weight:800; font-size:16px; color:#ea580c; background:#fff;">스마트스토어 구매하기 →</a><a href="/contact/" style="padding:14px 26px; border-radius:999px; font-weight:800; font-size:16px; color:#fff; background:rgba(255,255,255,.18); border:1.5px solid rgba(255,255,255,.5);">문의하기</a></div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var steps = document.getElementById('calc-steps');
      var width = document.getElementById('calc-width');
      var unit = document.getElementById('calc-unit');
      var type = document.getElementById('calc-type');
      var out = document.getElementById('calc-result');
      if (!steps || !width || !unit || !type || !out) return;
      function calc() {
        var s = parseFloat(steps.value), w = parseFloat(width.value), u = unit.value, t = type.value;
        width.placeholder = u === 'mm' ? '예: 1000' : '예: 100';
        if (!s || !w || s <= 0 || w <= 0) { out.innerHTML = '계단 단수와 한 단 폭을 입력해 주세요.'; return; }
        var wMeters = u === 'mm' ? w / 1000 : w / 100;
        var total = s * wMeters;
        var margin = total * 1.1;
        var f = function (n) { return (Math.round(n * 10) / 10).toFixed(1); };
        if (t === 'tape') {
          var r30 = Math.ceil(margin / 30), r15 = Math.ceil(margin / 15);
          out.innerHTML = '총 필요 길이 <b>약 ' + f(total) + 'm</b> (여유 포함 <b>' + f(margin) + 'm</b>)<br>→ 30m 롤 <b>' + r30 + '개</b> 또는 15m 롤 <b>' + r15 + '개</b>';
        } else {
          out.innerHTML = '한 단당 1개씩, 총 <b>' + s + '개</b> 필요 · 각 <b>' + w + u + '</b> 폭으로 재단<br>총 재단 길이 <b>약 ' + f(total) + 'm</b> (여유 포함 ' + f(margin) + 'm)';
        }
      }
      [steps, width, unit, type].forEach(function (el) { el.addEventListener('input', calc); el.addEventListener('change', calc); });
    })();
  </script>
</BaseLayout>

<style>
  .calc-in { width: 100%; margin-top: 6px; padding: 12px 14px; border: 1px solid #ecece6; border-radius: 12px; font-size: 15px; font-family: inherit; background: #fbfaf7; box-sizing: border-box; }
  .calc-in:focus { outline: none; border-color: #16a34a; background: #fff; }
  .catcard { transition: transform .12s ease, box-shadow .12s ease; }
  .catcard:hover { transform: translateY(-2px); box-shadow: 0 8px 22px rgba(31, 41, 55, .1); border-color: #16a34a; }
  @media (max-width: 820px) {
    .prod-detail { grid-template-columns: 1fr !important; }
    .cat-grid { grid-template-columns: repeat(2, 1fr) !important; }
    .calc-grid { grid-template-columns: 1fr !important; }
  }
</style>
